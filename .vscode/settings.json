{
  "actionButtons": {
    "defaultColor": "#68C147",
    "reloadButton": null,
    "loadNpmCommands": false,
    "commands": [
      {
        "name": "$(play) Backend",
        "color": "#68C147",
        "command": "npx nx serve backend"
      },
      {
        "name": "$(play) Frontend",
        "color": "#68C147",
        "command": "npx nx dev frontend"
      },
      {
        "name": "$(play) Plugin",
        "color": "#68C147",
        "command": "cd apps/wally && npm run start & npm run watch:css"
      },
      {
        "name": "$(sync) Generate API",
        "color": "#4FC3F7",
        "command": "npm run generate:api"
      },
      {
        "name": "$(tag) Patch",
        "color": "#FFB74D",
        "command": "npx nx version wally --bump=patch"
      },
      {
        "name": "$(tag) Minor",
        "color": "#FFB74D",
        "command": "npx nx version wally --bump=minor"
      },
      {
        "name": "$(tag) Major",
        "color": "#FFB74D",
        "command": "npx nx version wally --bump=major"
      },
      {
        "name": "$(package) Package",
        "color": "#CE93D8",
        "command": "npx nx package wally"
      }
    ]
  }
}
