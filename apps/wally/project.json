{
  "name": "wally",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/wally/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "npm run build",
          "npm run build:css"
        ],
        "cwd": "apps/wally",
        "parallel": false
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "npm run start",
          "npm run watch:css"
        ],
        "cwd": "apps/wally",
        "parallel": true
      }
    },
    "version": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "npm version {args.bump} --no-git-tag-version",
          "NEW_VER=$(node -p \"require('./package.json').version\") && sed -i '' \"s/^ \\* Version:.*/ * Version:     $NEW_VER/\" wally.php && sed -i '' \"s/define( 'WALLY_VERSION', '[^']*' )/define( 'WALLY_VERSION', '$NEW_VER' )/\" wally.php && echo \"Bumped to $NEW_VER\""
        ],
        "cwd": "apps/wally",
        "parallel": false
      }
    },
    "package": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "commands": [
          "rm -rf ../../dist/wally",
          "mkdir -p ../../dist/wally",
          "rsync -a --exclude-from=.distignore . ../../dist/wally/",
          "cd ../../dist && VERSION=$(node -p \"require('../apps/wally/package.json').version\") && zip -r wally-$VERSION.zip wally/",
          "rm -rf ../../dist/wally",
          "echo \"Package created: dist/wally-$(node -p \"require('./package.json').version\").zip\""
        ],
        "cwd": "apps/wally",
        "parallel": false
      }
    }
  }
}
